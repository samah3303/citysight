# CitySight — Environment Variables
# Copy this to .env and fill in your values

# ── YOLO model ──────────────────────────────────────────────────────────
# Options: yolov8n.pt (nano, ~6MB), yolov8s.pt (small, ~22MB)
YOLO_MODEL=yolov8n.pt
CONFIDENCE_THRESHOLD=0.4

# ── Video source ────────────────────────────────────────────────────────
# "0" = webcam, path to .mp4, or YouTube URL
VIDEO_SOURCE=0
FRAME_WIDTH=1280
FRAME_HEIGHT=720
TARGET_FPS=15

# ── Tracking ────────────────────────────────────────────────────────────
TRACKER_MAX_AGE=30
TRACKER_MIN_HITS=3
TRACKER_IOU_THRESHOLD=0.3

# ── Analytics ───────────────────────────────────────────────────────────
PIXELS_PER_METER=120.0
HEATMAP_HISTORY_FRAMES=300
DENSITY_LOW_THRESHOLD=5
DENSITY_MEDIUM_THRESHOLD=15

# ── Database (Neon PostgreSQL) — optional, falls back to no-op ──────────
DATABASE_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/citysight?sslmode=require

# ── DeepSeek alerting — optional, falls back to rule-based alerts ───────
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-chat
ALERT_CHECK_FRAMES=150
ALERT_DEVIATION_THRESHOLD=0.3

# ── Server ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
